# Copy to `.env.local` (which is gitignored) and fill in real values.
# Each section is independent — leave a section blank and that data source
# will fall back to placeholder values, so the dashboard still renders.

# ─── Sessions ────────────────────────────────────────────────────────────────
# Long random string (e.g. `openssl rand -base64 48`). HMAC key for the
# session cookie. Required in production. If unset, dev falls back to an
# insecure built-in secret and warns once on the server console.
SESSION_SECRET=

# ─── Database (LibSQL / SQLite) ──────────────────────────────────────────────
# Where the user/auth tables live. When unset, dev uses a local SQLite file
# at ./data/wbb.db (created on first boot, seeded from lib/users/users.json).
# For production (Vercel can't write to disk), point at a hosted LibSQL —
# Turso is the easiest: https://turso.tech (free tier covers everything).
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Used for invite + password-reset emails. When RESEND_API_KEY is unset,
# emails print to the server console instead of sending — useful for local
# dev. Verify wbcustomerportal.com in the Resend dashboard before going live.
RESEND_API_KEY=
EMAIL_FROM="WB Blends Portal <noreply@wbcustomerportal.com>"

# Public origin used to build links inside outbound emails. In production,
# this is your Vercel URL or custom domain (e.g. https://portal.wbblends.com).
PUBLIC_BASE_URL=http://localhost:3000

# Who gets the notification email each time a customer submits the Customer
# Experience Survey (/q2-2026-survey). Comma-separated. When unset, defaults
# to dsimmons@westernbotanicals.com.
SURVEY_NOTIFY_EMAILS=dsimmons@westernbotanicals.com

# ─── HubSpot ─────────────────────────────────────────────────────────────────
# Quickest one to set up (~5 min):
#   HubSpot → Settings → Integrations → Private Apps → Create
#   Scopes required: crm.objects.deals.read, crm.objects.contacts.read
HUBSPOT_PRIVATE_APP_TOKEN=

# ─── Google Ads ──────────────────────────────────────────────────────────────
# Apply for Basic Access dev token: Google Ads Manager → Tools → API Center
# (1–3 business days for approval)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
# Optional — set to your manager (MCC) account ID if querying through one
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─── LinkedIn Ads (CSV-fed, no API) ──────────────────────────────────────────
# Schedule a daily spend CSV from Campaign Manager into a folder, then point
# this at it. Skips the multi-week LinkedIn Marketing Developer Platform
# approval process entirely.
LINKEDIN_CSV_DIR=

# ─── Tickets sync (coworker → portal) ────────────────────────────────────────
# Shared secret the 7 AM coworker job sends as `Authorization: Bearer <token>`
# when POSTing parsed PM tickets to /api/tickets/sync. Generate a long random
# string (e.g. `openssl rand -base64 48`). If unset, /api/tickets/sync returns
# 503 — the admin Tickets page still renders any rows that synced previously.
TICKETS_SYNC_TOKEN=
