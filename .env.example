# =============================================================================
# WB Blends Portal — environment variables
# =============================================================================
# Copy to `.env.local` for local dev. In production, set these in
# Vercel → Project Settings → Environment Variables. Never commit `.env*`.
#
# The portal currently runs entirely on mock data (`lib/data/*.ts`) and does
# NOT require any of these to boot. They are read lazily by `lib/acumatica/*`
# when a loader switches over from mock to real.

# -----------------------------------------------------------------------------
# Acumatica ERP — Contract-Based REST API
# -----------------------------------------------------------------------------

# Instance base URL (no trailing slash, no path).
ACUMATICA_BASE_URL=https://wbblends.acumatica.com

# Tenant / Company ID. Matches the "Company" field on the login screen.
ACUMATICA_TENANT=WBBlends

# OAuth 2.0 client — created in Acumatica's Connected Applications screen
# (SM303010). Client ID has the form "<guid>@<TenantID>".
ACUMATICA_OAUTH_CLIENT_ID=00000000-0000-0000-0000-000000000000@WBBlends
ACUMATICA_OAUTH_CLIENT_SECRET=changeme

# Service account credentials. Only used when grant_type=password (default
# when both are present). Omit both to fall back to client_credentials.
ACUMATICA_OAUTH_USERNAME=portal-svc
ACUMATICA_OAUTH_PASSWORD=changeme

# OAuth scopes. `api` is required. Add `api:concurrent_access` if your tenant
# has limited API session seats. `offline_access` enables refresh tokens.
ACUMATICA_OAUTH_SCOPE=api offline_access

# Endpoint identifiers. Defaults match a stock Acumatica install.
ACUMATICA_DEFAULT_ENDPOINT=Default
ACUMATICA_MFG_ENDPOINT=Manufacturing

# Endpoint version — PIN this. Floating to "Latest" silently changes schema
# during tenant upgrades and breaks the portal. Bump deliberately and verify
# against the live Swagger before deploying.
ACUMATICA_ENDPOINT_VERSION=24.200.001

# Tunables
ACUMATICA_REQUEST_TIMEOUT_MS=30000
ACUMATICA_MAX_PAGE_SIZE=200
